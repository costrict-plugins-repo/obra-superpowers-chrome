{
  "name": "superpowers-chrome-mcp",
  "version": "3.0.2",
  "description": "Ultra-lightweight Chrome DevTools Protocol MCP server with auto-capture",
  "type": "module",
  "main": "mcp/dist/index.js",
  "bin": {
    "superpowers-chrome-mcp": "mcp/dist/index.js"
  },
  "scripts": {
    "build": "cd mcp && npm install && npm run build",
    "prepare": "npm run build",
    "start": "node mcp/dist/index.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "npm run lint && ./scripts/check-bundle-fresh.sh && node --test 'test/**/*.test.mjs'"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "mcp/dist/",
    "skills/browsing/chrome-ws-lib.js",
    "skills/browsing/host-override.js",
    "skills/browsing/lib/",
    "skills/browsing/package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "mcp",
    "chrome",
    "browser",
    "automation",
    "devtools",
    "claude",
    "ai"
  ],
  "author": {
    "name": "Jesse Vincent",
    "email": "jesse@fsck.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/obra/superpowers-chrome.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "jsdom": "^29.0.2"
  }
}
